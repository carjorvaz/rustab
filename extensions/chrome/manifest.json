{
  "manifest_version": 3,
  "name": "rustab",
  "version": "0.1.0",
  "description": "Browser tab management from the terminal",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
