{
  "manifest_version": 2,
  "name": "rustab",
  "version": "0.1.5",
  "description": "Browser tab management from the terminal",
  "permissions": [
    "nativeMessaging",
    "tabs"
  ],
  "background": {
    "scripts": ["background_core.js", "background.js"],
    "persistent": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rustab@rustab.dev",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "74.0"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
